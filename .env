# BioReason-X Environment Configurations

# LLM Providers Configuration (options: vllm, openai, gemini)
LLM_PROVIDER=vllm

# local AMD vLLM server endpoints
VLLM_TEXT_API_BASE=http://localhost:8002/v1
VLLM_TEXT_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ


VLLM_VISION_API_BASE=http://localhost:8001/v1
VLLM_VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct-AWQ

# Fallbacks (Optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_MODEL=gpt-4o

GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_MODEL=gemini-2.5-flash
